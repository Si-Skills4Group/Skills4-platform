# API App Service settings
NODE_ENV=production
PORT=8080
DATABASE_URL=postgres://<user>:<password>@<server>.postgres.database.azure.com:5432/<database>?sslmode=require
JWT_SECRET=<generate-a-strong-random-value>
JWT_EXPIRES_IN=7d
LOG_LEVEL=info
CORS_ORIGIN=https://<your-static-web-app>.azurestaticapps.net

# Frontend build-time setting
VITE_API_BASE_URL=https://<your-api-app>.azurewebsites.net
